# Database (used when running outside Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=opspilot_desk
DB_USER=opspilot
DB_PASSWORD=opspilot

# JWT
# Use a long random string in production (min 32 chars)
JWT_SECRET=change-me-in-production-use-long-random-secret
JWT_EXPIRATION_MS=86400000

# OpenRouter AI
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-3.5-turbo
OPENROUTER_MAX_TOKENS=1024
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_TIMEOUT_SECONDS=30

# Set to true to use fake AI provider (no API key needed)
FAKE_AI=false

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:4200
