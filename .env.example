# PostgreSQL
POSTGRES_DB=opspilot
POSTGRES_USER=opspilot
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Spring Boot datasource (used inside Docker Compose network)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/opspilot

# JWT -- generate with: openssl rand -base64 64
JWT_SECRET=replace-with-base64-encoded-secret-min-32-bytes
JWT_EXPIRATION_MS=3600000

# CORS -- comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:4200

# OpenRouter (Phase 3)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_TIMEOUT_SECONDS=30

# AI Provider: fake or openrouter
AI_PROVIDER=fake
