# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/opspilot
DATABASE_USERNAME=opspilot
DATABASE_PASSWORD=opspilot

# JWT
JWT_SECRET=change-me-in-production-must-be-at-least-32-characters-long
JWT_EXPIRATION_MS=86400000

# OpenRouter AI
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-3.5-turbo
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_TOKENS=1000
OPENROUTER_TEMPERATURE=0.7
# Set to true to use fake AI responses (no API key required)
OPENROUTER_FAKE_MODE=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200
